{
  "inputs": [
    {
      "id": "sonarqubeToken",
      "type": "promptString",
      "description": "SonarQube user token"
    }
  ],
  "servers": {
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    },
    "sonarqube": {
      "command": "podman",
      "args": [
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        //"-e",
        //"SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${input:sonarqubeToken}",
        "SONARQUBE_ORG": "tjeerdmenno",
        //"SONARQUBE_URL": "https://sonarqube.us"
      }
    }
  }
}